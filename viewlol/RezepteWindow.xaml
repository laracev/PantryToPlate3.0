<Window x:Class="PantryToPlate.RezepteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezeptempfehlungen" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#F7F9FC">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#8360A6"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#C0A7D9"/>
        <SolidColorBrush x:Key="WarningColor" Color="#C6D9B4"/>
        <SolidColorBrush x:Key="InfoColor" Color="#9ABF75"/>
        <SolidColorBrush x:Key="LightGray" Color="#F7E3FC"/>
        <SolidColorBrush x:Key="MediumGray" Color="#BDC3C7"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" 
                CornerRadius="12" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="📖 Rezeptempfehlungen" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Hauptinhalt -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Rezeptliste -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,15,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Kategorie Filter -->
                    <Border Grid.Row="0" Background="{StaticResource LightGray}" Padding="15,10" CornerRadius="12,12,0,0">
                        <StackPanel>
                            <TextBlock Text="📂 Kategorie" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cboKategorie" SelectionChanged="cboKategorie_SelectionChanged">
                                <ComboBoxItem Content="📋 Alle Rezepte" Tag="Alle" IsSelected="True"/>
                                <ComboBoxItem Content="🍝 Pasta" Tag="Pasta"/>
                                <ComboBoxItem Content="🥗 Bowl" Tag="Bowl"/>
                                <ComboBoxItem Content="🍕 Normale Pizza" Tag="Normale Pizza"/>
                                <ComboBoxItem Content="🌱 Vegane Pizza" Tag="Vegane Pizza"/>
                                <ComboBoxItem Content="🍛 Curry" Tag="Curry"/>
                                <ComboBoxItem Content="🥣 Suppe" Tag="Suppe"/>
                                <ComboBoxItem Content="🍲 Auflauf" Tag="Auflauf"/>
                                <ComboBoxItem Content="🍳 Omelett" Tag="Omelett"/>
                                <ComboBoxItem Content="🌯 Wrap" Tag="Wrap"/>
                                <ComboBoxItem Content="🍳 Pfannengericht" Tag="Pfannengericht"/>
                                <ComboBoxItem Content="🔥 Ofengericht" Tag="Ofengericht"/>
                                <ComboBoxItem Content="🍰 Kuchen" Tag="Kuchen"/>
                                <ComboBoxItem Content="🍪 Kekse" Tag="Kekse"/>
                                <ComboBoxItem Content="🥤 Smoothie" Tag="Smoothie"/>
                                <ComboBoxItem Content="🌅 Frühstück" Tag="Frühstück"/>
                                <ComboBoxItem Content="🍮 Dessert" Tag="Dessert"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Suche -->
                    <Border Grid.Row="1" Background="White" Padding="15,10" CornerRadius="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtSuche" Grid.Column="0" Height="35" Padding="10,0"
                                     TextChanged="txtSuche_TextChanged"/>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="18" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Liste -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#F8F9FA">
                        <StackPanel x:Name="spRezeptListe" Margin="10"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Rezeptdetails -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="spDetails" Margin="20">
                        <!-- Rezeptname -->
                        <TextBlock x:Name="txtRezeptName" FontSize="22" FontWeight="Bold" 
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Foreground="{StaticResource PrimaryColor}"
                                   Margin="0,0,0,15"/>

                        <!-- Kein Rezept ausgewählt -->
                        <TextBlock x:Name="txtKeinRezept" Text="👈 Wähle ein Rezept aus der Liste"
                                   FontSize="16" Foreground="Gray"
                                   HorizontalAlignment="Center" Margin="0,50,0,0"
                                   Visibility="Visible"/>

                        <!-- Details Inhalt (wird sichtbar wenn Rezept ausgewählt) -->
                        <StackPanel x:Name="spDetailsInhalt" Visibility="Collapsed">
                            <!-- Kalorien -->
                            <Border Background="{StaticResource InfoColor}" CornerRadius="10" 
                                    Padding="12" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="🔥 Kalorien pro Portion" 
                                               Foreground="White" TextAlignment="Center"
                                               FontSize="12"/>
                                    <TextBlock x:Name="txtKalorien" Text="0 kcal" 
                                               FontSize="28" FontWeight="Bold" 
                                               Foreground="White" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Zutaten -->
                            <TextBlock Text="📝 Zutaten" FontWeight="SemiBold" 
                                       FontSize="14" Margin="0,0,0,10"/>

                            <StackPanel x:Name="spZutaten" Margin="0,0,0,15"/>

                            <!-- Anleitung -->
                            <TextBlock Text="📖 Anleitung" FontWeight="SemiBold" 
                                       FontSize="14" Margin="0,15,0,10"/>

                            <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                                <TextBlock x:Name="txtAnleitung" Text="-" 
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Verfügbarkeit -->
                            <Border Background="#F0F0F0" CornerRadius="10" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="📦 Verfügbarkeit" 
                                               FontWeight="Bold" TextAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" 
                                                HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <Button x:Name="btnFehlendeKaufen" 
                                                Content="🛒 Fehlende kaufen" Width="160" Margin="5"
                                                Click="btnFehlendeKaufen_Click"/>
                                        <Button x:Name="btnRezeptKochen" 
                                                Content="🍳 Rezept kochen" Width="140" Margin="5"
                                                Style="{StaticResource SuccessButton}"
                                                Click="btnRezeptKochen_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Button Grid.Row="2" x:Name="btnSchliessen" Content="Schließen" 
                Width="100" Height="35" HorizontalAlignment="Center" 
                Margin="0,15,0,0" Click="btnSchliessen_Click"/>
    </Grid>
</Window>