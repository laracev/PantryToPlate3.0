<Window x:Class="PantryToPlate.RezepteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rezepte" WindowState="Maximized" MinWidth="900" MinHeight="620"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource PantryWindowBackgroundBrush}" Foreground="{DynamicResource WindowTextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="Purple" Color="{DynamicResource PantryPrimaryColorValue}"/>
        <SolidColorBrush x:Key="Green" Color="{DynamicResource RecipeGreenColorValue}"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Purple}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
            <Setter Property="Padding" Value="11,7"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource Purple}" CornerRadius="7" Padding="15" Margin="0,0,0,12">
            <TextBlock Text="Rezepte" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource WhiteTextBrush}" HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Rezepte suchen" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Kategorie" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cboKategorie" Height="34" SelectionChanged="cboKategorie_SelectionChanged">
                            <ComboBoxItem Content="Alle Rezepte" Tag="Alle" IsSelected="True"/>
                            <ComboBoxItem Content="Pasta" Tag="Pasta"/>
                            <ComboBoxItem Content="Bowl" Tag="Bowl"/>
                            <ComboBoxItem Content="Normale Pizza" Tag="Normale Pizza"/>
                            <ComboBoxItem Content="Vegane Pizza" Tag="Vegane Pizza"/>
                            <ComboBoxItem Content="Curry" Tag="Curry"/>
                            <ComboBoxItem Content="Suppe" Tag="Suppe"/>
                            <ComboBoxItem Content="Auflauf" Tag="Auflauf"/>
                            <ComboBoxItem Content="Omelett" Tag="Omelett"/>
                            <ComboBoxItem Content="Wrap" Tag="Wrap"/>
                            <ComboBoxItem Content="Pfannengericht" Tag="Pfannengericht"/>
                            <ComboBoxItem Content="Ofengericht" Tag="Ofengericht"/>
                            <ComboBoxItem Content="Kuchen" Tag="Kuchen"/>
                            <ComboBoxItem Content="Kekse" Tag="Kekse"/>
                            <ComboBoxItem Content="Smoothie" Tag="Smoothie"/>
                            <ComboBoxItem Content="Frühstück" Tag="Frühstück"/>
                            <ComboBoxItem Content="Dessert" Tag="Dessert"/>
                        </ComboBox>
                        <TextBlock Text="Suche" Margin="0,9,0,4"/>
                        <TextBox x:Name="txtSuche" Height="34" Padding="8,0" VerticalContentAlignment="Center" TextChanged="txtSuche_TextChanged"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="spRezeptListe"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="spDetails">
                        <TextBlock x:Name="txtRezeptName" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <TextBlock x:Name="txtKeinRezept" Text="Wähle links ein Rezept aus." Foreground="{DynamicResource PantryMutedTextBrush}" HorizontalAlignment="Center" Margin="0,45,0,0"/>
                        <StackPanel x:Name="spDetailsInhalt" Visibility="Collapsed">
                            <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="5" Padding="10" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Kalorien pro Portion" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="txtKalorien" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Zutaten" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                            <StackPanel x:Name="spZutaten" Margin="0,0,0,14"/>
                            <TextBlock Text="Anleitung" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource RecipeInstructionBackgroundBrush}" BorderBrush="{DynamicResource RecipeInstructionBorderBrush}" BorderThickness="1" CornerRadius="5" Padding="12">
                                <TextBlock x:Name="txtAnleitung" TextWrapping="Wrap"/>
                            </Border>
                            <WrapPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                                <Button x:Name="btnFehlendeKaufen" Content="Fehlende Zutaten kaufen" Margin="4" Click="btnFehlendeKaufen_Click"/>
                                <Button x:Name="btnRezeptKochen" Content="Rezept kochen" Margin="4" Background="{StaticResource Green}" Click="btnRezeptKochen_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Button x:Name="btnSchliessen" Grid.Row="2" Content="Schließen" Width="100" HorizontalAlignment="Center" Margin="0,12,0,0" Click="btnSchliessen_Click" Foreground="White" Background="#FFC2A0E3"/>
    </Grid>
</Window>