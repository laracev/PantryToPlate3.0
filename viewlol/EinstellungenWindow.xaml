<Window x:Class="PantryToPlate.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Height="871" Width="1057"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="{DynamicResource StandardWindowBackgroundBrush}"
        Foreground="{DynamicResource WindowTextBrush}">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="{DynamicResource StandardPrimaryColorValue}"/>
        <SolidColorBrush x:Key="Success" Color="{DynamicResource StandardSuccessColorValue}"/>
        <SolidColorBrush x:Key="Danger" Color="{DynamicResource StandardDangerLightColorValue}"/>
        <SolidColorBrush x:Key="Warning" Color="{DynamicResource StandardNeutralColorValue}"/>
        <SolidColorBrush x:Key="TextDark" Color="{DynamicResource StandardTextDarkColorValue}"/>
        <SolidColorBrush x:Key="TextGray" Color="{DynamicResource StandardTextGrayColorValue}"/>
        <SolidColorBrush x:Key="BgWhite" Color="{DynamicResource StandardSurfaceColorValue}"/>
        <SolidColorBrush x:Key="BgGray" Color="{DynamicResource StandardSurfaceAltColorValue}"/>

        <DataTemplate x:Key="ComboBoxBlackTextTemplate">
            <TextBlock Text="{Binding}" Foreground="Black"/>
        </DataTemplate>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgWhite}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{StaticResource BgWhite}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StandardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#E5E5E5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#E5E5E5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="ContentTemplate" Value="{StaticResource ComboBoxBlackTextTemplate}"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C8C8C8"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="TextElement.Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextGray}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,20,20,11">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Primary}" CornerRadius="8" Padding="20" Margin="0,5,0,13">
            <StackPanel>
                <TextBlock Text="Einstellungen" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Height="30"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,1">
            <StackPanel>

                <Border Style="{StaticResource Card}" Margin="0,0,0,15" Height="417">
                    <StackPanel>

                        <TextBlock Style="{StaticResource Label}" Text="Gewicht (kg)"/>
                        <TextBox x:Name="txtGewicht" Margin="0,0,0,15" Height="33"/>

                        <TextBlock Style="{StaticResource Label}" Text="Größe (cm)"/>
                        <TextBox x:Name="txtGroesse" Margin="0,0,0,15" Height="30"/>

                        <TextBlock Style="{StaticResource Label}" Text="Alter"/>
                        <TextBox x:Name="txtAlter" Margin="0,0,0,15" Height="27"/>

                        <TextBlock Style="{StaticResource Label}" Text="Geschlecht"/>
                        <ComboBox x:Name="cboGeschlecht" Margin="0,0,0,15" Height="29">
                            <ComboBoxItem Content="Weiblich"/>
                            <ComboBoxItem Content="Männlich"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource Label}" Text="Aktivitätslevel"/>
                        <ComboBox x:Name="cboAktivitaet" Margin="0,0,0,15" Height="28">
                            <ComboBoxItem Content="Wenig bewegt (1.2)"/>
                            <ComboBoxItem Content="Leicht aktiv (1.375)"/>
                            <ComboBoxItem Content="Mäßig aktiv (1.55)"/>
                            <ComboBoxItem Content="Sehr aktiv (1.725)"/>
                        </ComboBox>

                        <TextBlock Style="{StaticResource Label}" Text="Ziel"/>
                        <ComboBox x:Name="cboZiel" Margin="0,0,0,10" Height="28">
                            <ComboBoxItem Content="⬇️ Abnehmen (-500 kcal)"/>
                            <ComboBoxItem Content="Gewicht halten (0 kcal)"/>
                            <ComboBoxItem Content="⬆️ Zunehmen (+500 kcal)"/>
                        </ComboBox>

                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,15" Height="226">
                    <StackPanel>
                        <TextBlock Text="Dein Kalorienziel" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>

                        <Border Background="{StaticResource Primary}" CornerRadius="8" Padding="20" Margin="0,0,0,15" Height="113">
                            <StackPanel>
                                <TextBlock x:Name="txtKalorienZiel" Text="0" FontSize="48" FontWeight="Bold" Foreground="White" TextAlignment="Center" Height="54" Width="608"/>
                                <TextBlock Text="kcal pro Tag" Foreground="{DynamicResource StandardKcalSubtitleBrush}" TextAlignment="Center" FontSize="14" Height="21"/>
                            </StackPanel>
                        </Border>

                        <Button x:Name="btnBerechnen" Content="Empfehlung berechnen" Click="btnBerechnen_Click" Height="19" Width="190" Background="#FF8F60CC"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnSpeichern" Content="Speichern" Width="120" Click="btnSpeichern_Click" Height="41" Background="#FF8E63A0"/>
                    <Button x:Name="btnAbbrechen" Content="Abbrechen" Width="100" Margin="10,0,0,0" Click="btnAbbrechen_Click" Background="#FFFF4E4E"/>
                    <CheckBox x:Name="chkDarkMode" Content="Dark Mode verwenden" Margin="0,10" Checked="chkDarkMode_Changed" Unchecked="chkDarkMode_Changed"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>