<Window x:Class="PantryToPlate.EinkaufslisteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einkaufsliste" 
        Height="500" Width="724"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        Background="#F5F6F8">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#6F5A8A"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#AFA0C4"/>
        <SolidColorBrush x:Key="DangerColor" Color="#D7E3CF"/>
        <SolidColorBrush x:Key="WarningColor" Color="#7FA36A"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>

        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Meine Einkaufsliste" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Hake ab was du gekauft hast" FontSize="12" Foreground="#D9D4DF" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="spEinkaufsliste" Margin="0"/>
            </ScrollViewer>
        </Border>


        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnGekaufteEntfernen" Content="✓ Gekaufte zur Pantry hinzufügen" Background="{StaticResource WarningColor}" Width="220" Margin="5" Click="btnGekaufteEntfernen_Click"/>
            <Button x:Name="btnLeeren" Content="Liste leeren" Background="#E74C3C" Width="120" Margin="5" Click="btnLeeren_Click"/>
            <Button x:Name="btnSchliessen" Content="Schließen" Width="100" Margin="5" Click="btnSchliessen_Click"/>
        </StackPanel>
    </Grid>
</Window>