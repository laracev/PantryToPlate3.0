<Window x:Class="PantryToPlate.FitnessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚡ Fitness" Height="753" Width="1097"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="{DynamicResource StandardWindowBackgroundBrush}"
        Foreground="{DynamicResource WindowTextBrush}">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="{DynamicResource StandardPrimaryColorValue}"/>
        <SolidColorBrush x:Key="InfoColor" Color="{DynamicResource StandardDangerLightColorValue}"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>

        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>




        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#E5E5E5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextElement.Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="⚡ Fitness Aktivität" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource WhiteTextBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Erfasse deine verbrannten Kalorien" FontSize="12" Foreground="{DynamicResource StandardHeaderSubtitleBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Aktivität" FontWeight="Medium" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cboAktivitaet" Height="40" Margin="0,0,0,15" SelectionChanged="cboAktivitaet_SelectionChanged"/>

                        <TextBlock Text="dauer (Minuten)" FontWeight="Medium" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtDauer" Height="40" TextChanged="txtDauer_TextChanged"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource InfoColor}" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Verbrannte Kalorien" FontWeight="Bold" Foreground="{DynamicResource WhiteTextBrush}" TextAlignment="Center"/>
                        <TextBlock x:Name="txtVerbrannteKalorien" Text="0 kcal" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource WhiteTextBrush}" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Heutige Aktivitäten" FontWeight="Medium" Margin="0,0,0,10"/>
                        <ListBox x:Name="lstAktivitaeten" Height="150" BorderThickness="0" SelectionMode="Single"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Button x:Name="btnSpeichern" Content="Speichern" Width="120" Margin="5" Click="btnSpeichern_Click" Background="#FFA9FF45"/>
                    <Button x:Name="btnLoeschen" Content="Löschen" Width="110" Margin="5" Click="btnLoeschen_Click" Background="#FFFF3939"/>
                    <Button x:Name="btnSchliessen" Content="Schließen" Width="100" Margin="5" Click="btnSchliessen_Click" Background="#FF9743FF"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>