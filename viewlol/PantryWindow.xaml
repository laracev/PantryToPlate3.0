<Window x:Class="PantryToPlate.PantryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pantry" WindowState="Maximized" MinWidth="850" MinHeight="600"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource PantryWindowBackgroundBrush}" Foreground="{DynamicResource WindowTextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="Purple" Color="{DynamicResource PantryPrimaryColorValue}"/>
        <SolidColorBrush x:Key="Light" Color="{DynamicResource PantryLightColorValue}"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Purple}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
            <Setter Property="Padding" Value="11,7"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PantryInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PantryBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource PantryBorderBrush}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DataGridHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
        </Style>

    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="{StaticResource Purple}" CornerRadius="7" Padding="15" Margin="0,0,0,12">
            <TextBlock Text="Meine Pantry" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource WhiteTextBrush}" HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Lebensmittel hinzufügen" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtSuche" TextChanged="txtSuche_TextChanged"/>
                        <Button x:Name="btnAlleAnzeigen" Grid.Column="1" Content="Alle anzeigen" Margin="8,0,0,0" Click="btnAlleAnzeigen_Click" Background="#FFA950FF"/>
                    </Grid>
                    <ListBox x:Name="lstLebensmittel" Grid.Row="2" SelectionChanged="lstLebensmittel_SelectionChanged" BorderBrush="{DynamicResource PantryBorderBrush}" BorderThickness="1"/>
                    <TextBlock x:Name="txtAnzahlErgebnisse" Grid.Row="3" Foreground="{DynamicResource PantryMutedTextBrush}" Margin="0,6,0,10"/>
                    <Border Grid.Row="4" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="5" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Ausgewählt" FontSize="11"/>
                                <TextBlock x:Name="txtAusgewaehltes" Text="-" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="12,0">
                                <TextBlock Text="Menge in g" FontSize="11"/>
                                <TextBox x:Name="txtMenge" Width="80" TextAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="btnZurPantryHinzufuegen" Grid.Column="2" Content="Hinzufügen" VerticalAlignment="Bottom" Click="btnZurPantryHinzufuegen_Click" Background="#FF9726FF"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Vorräte" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <DataGrid x:Name="dgPantry" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Lebensmittel" Width="*" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="Menge (g)" Width="110" Binding="{Binding Menge}"/>
                            <DataGridTemplateColumn Header="" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Löschen" Padding="8,4" Background="{DynamicResource PantryDeleteBrush}" Click="btnLoeschen_Click" Tag="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Button x:Name="btnSchliessen" Grid.Row="2" Content="Schließen" Width="100" HorizontalAlignment="Center" Margin="0,12,0,0" Click="btnSchliessen_Click" Background="#FFB466FF"/>
    </Grid>
</Window>