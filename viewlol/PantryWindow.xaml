<Window x:Class="PantryToPlate.PantryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vorratskammer"
        WindowState="Maximized"
        Height="861" Width="1224"
        WindowStartupLocation="CenterOwner"
        Background="#F0F4F8">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#8360A6"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#9ABF75"/>
        <SolidColorBrush x:Key="Success" Color="#C0A7D9"/>
        <SolidColorBrush x:Key="Danger" Color="#C6D9B4"/>
        <SolidColorBrush x:Key="Warning" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="TextDark" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextGray" Color="#64748B"/>
        <SolidColorBrush x:Key="BgWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgGray" Color="#F1F5F9"/>

        <!-- Einfacher Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgWhite}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{StaticResource BgWhite}"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="140"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{StaticResource BgGray}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" Margin="{TemplateBinding Margin}">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource Primary}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Primary}" 
                CornerRadius="16" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Pantry" 
                           FontSize="26" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"/>
            
            </StackPanel>
        </Border>

      
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>

                
                <Border Style="{StaticResource Card}" Margin="0,0,0,15" Height="368">
                    <StackPanel>
                        <TextBlock Text="Lebensmittel hinzufügen" FontSize="16" FontWeight="Bold"  Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtSuche" Grid.Column="0" TextChanged="txtSuche_TextChanged"/>
                            <Button x:Name="btnAlleAnzeigen" Grid.Column="1" Content="Alle" Width="60" Margin="10,0,0,0" Background="{StaticResource Primary}" Click="btnAlleAnzeigen_Click"/>
                        </Grid> 
                        
                        <ListBox x:Name="lstLebensmittel" SelectionChanged="lstLebensmittel_SelectionChanged"/>

                        <TextBlock x:Name="txtAnzahlErgebnisse" FontSize="11" Foreground="{StaticResource TextGray}" Margin="0,5,0,10"/>

                        
                        <Border Background="{StaticResource BgGray}" CornerRadius="12" Padding="15" Margin="0,5,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Ausgewählt" FontSize="11" Foreground="{StaticResource TextGray}"/>
                                    <TextBlock x:Name="txtAusgewaehltes" Text="-" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Primary}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="15,0">
                                    <TextBlock Text="Gramm" FontSize="11" Foreground="{StaticResource TextGray}"/>
                                    <TextBox x:Name="txtMenge" Text="100" Width="80"
                                             TextAlignment="Center"/>
                                </StackPanel>

                                <Button x:Name="btnZurPantryHinzufuegen" Grid.Column="2" Content="➕ Hinzufügen" Width="100" Height="38" Background="{StaticResource Success}" Click="btnZurPantryHinzufuegen_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Height="254">
                    <StackPanel>
                        <TextBlock Text="Meine Vorräte" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>

                        <DataGrid x:Name="dgPantry" AutoGenerateColumns="False" Height="211">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Lebensmittel" Width="*" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="Menge (g)" Width="100" Binding="{Binding Menge}"/>
                                <DataGridTemplateColumn Header="" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Löschen" Width="60" Height="28" Background="{StaticResource Danger}" FontSize="11" Click="btnLoeschen_Click" Tag="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                
                <Button x:Name="btnSchliessen" Content="Schließen" Width="100" Height="38" HorizontalAlignment="Center" Margin="0,20,0,0" Background="{StaticResource Primary}" Click="btnSchliessen_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>