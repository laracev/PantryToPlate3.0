<Window x:Class="PantryToPlate.MahlzeitHinzufuegenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mahlzeit hinzufügen" 
        Height="846" Width="1228"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="{DynamicResource StandardWindowBackgroundBrush}"
        Foreground="{DynamicResource WindowTextBrush}">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="{DynamicResource StandardPrimaryColorValue}"/>
        <SolidColorBrush x:Key="Success" Color="{DynamicResource StandardSuccessColorValue}"/>
        <SolidColorBrush x:Key="Danger" Color="{DynamicResource StandardDangerLightColorValue}"/>
        <SolidColorBrush x:Key="Warning" Color="{DynamicResource StandardNeutralColorValue}"/>
        <SolidColorBrush x:Key="TextDark" Color="{DynamicResource StandardTextDarkColorValue}"/>
        <SolidColorBrush x:Key="TextGray" Color="{DynamicResource StandardTextGrayColorValue}"/>
        <SolidColorBrush x:Key="BgWhite" Color="{DynamicResource StandardSurfaceColorValue}"/>
        <SolidColorBrush x:Key="BgGray" Color="{DynamicResource StandardSurfaceAltColorValue}"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource WindowTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StandardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Height" Value="160"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">

                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="6" Margin="{TemplateBinding Margin}">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource Primary}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Background="{StaticResource Primary}" 
                CornerRadius="8" Padding="20" Margin="0,10,0,6">
            <StackPanel>
                <TextBlock Text="➕ Mahlzeit hinzufügen" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource WhiteTextBrush}" HorizontalAlignment="Center" Height="28"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,-4">
            <StackPanel>


                <Border Style="{StaticResource Card}" Margin="0,0,0,15" Height="230">
                    <StackPanel>
                        <TextBlock Text="Lebensmittel suchen" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtSuche" Grid.Column="0" TextChanged="txtSuche_TextChanged"/>
                            <Button x:Name="btnSuchen" Grid.Column="1" Content="Suchen" Width="80" Margin="10,0,0,0" Click="btnSuchen_Click" Foreground="#FFFAFAFA" BorderBrush="#FFFCCACA" Background="#FFF9B5F2"/>
                        </Grid>

                        <ListBox x:Name="lstLebensmittel" SelectionChanged="lstLebensmittel_SelectionChanged"/>

                        <TextBlock x:Name="txtAnzahlErgebnisse" FontSize="11" Foreground="{StaticResource TextGray}" Margin="0,8,0,0" TextAlignment="Right"/>
                    </StackPanel>
                </Border>


                <Border Style="{StaticResource Card}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Ausgewähltes Lebensmittel" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>

                        <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" Height="54">
                            <TextBlock x:Name="txtAusgewaehltes" Text="Kein Lebensmittel ausgewählt" FontSize="15" FontWeight="Medium" Foreground="{StaticResource Primary}" TextAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Menge (Gramm)" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextGray}" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtGramm" Text="100" TextChanged="txtGramm_TextChanged"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Height="181">
                    <StackPanel>
                        <TextBlock Text="Nährwerte für diese Portion" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextDark}" Margin="0,0,0,15"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Kalorien:" FontWeight="Medium" Margin="0,0,15,10"/>
                            <TextBlock x:Name="txtKalorien" Grid.Row="0" Grid.Column="1" Text="0 kcal" Foreground="{StaticResource Primary}" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Proteine:" FontWeight="Medium" Margin="0,0,15,10"/>
                            <TextBlock x:Name="txtProteine" Grid.Row="1" Grid.Column="1" Text="0 g" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Kohlenhydrate:" FontWeight="Medium" Margin="0,0,15,10"/>
                            <TextBlock x:Name="txtKohlenhydrate" Grid.Row="2" Grid.Column="1" Text="0 g" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Fett:" FontWeight="Medium" Margin="0,0,15,10"/>
                            <TextBlock x:Name="txtFett" Grid.Row="3" Grid.Column="1" Text="0 g" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Ballaststoffe:" FontWeight="Medium" Margin="0,0,15,0"/>
                            <TextBlock x:Name="txtBallaststoffe" Grid.Row="4" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="btnHinzufuegen" Content="➕ Hinzufügen" Width="120" Click="btnHinzufuegen_Click" Background="#FFAF76FF"/>
                    <Button x:Name="btnAbbrechen" Content="Abbrechen" Width="100" Margin="10,0,0,0" Click="btnAbbrechen_Click" Background="#FFADFF76"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>