<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- mit chatty -->
    <Color x:Key="MainPrimaryColorValue">#896bb4</Color>
    <Color x:Key="MainSecondaryColorValue">#F2F2F2</Color>
    <Color x:Key="MainSuccessColorValue">#C0A7D9</Color>
    <Color x:Key="MainWarningColorValue">#C6D9B4</Color>
    <Color x:Key="MainInfoColorValue">#9ABF75</Color>
    <Color x:Key="MainLightGrayColorValue">#F7E3FC</Color>
    <Color x:Key="MainMediumGrayColorValue">#BDC3C7</Color>

    <Color x:Key="StandardPrimaryColorValue">#6F5A8A</Color>
    <Color x:Key="StandardSuccessColorValue">#AFA0C4</Color>
    <Color x:Key="StandardDangerLightColorValue">#D7E3CF</Color>
    <Color x:Key="StandardWarningColorValue">#7FA36A</Color>
    <Color x:Key="StandardNeutralColorValue">#F2F2F2</Color>
    <Color x:Key="StandardTextDarkColorValue">#2E2933</Color>
    <Color x:Key="StandardTextGrayColorValue">#6E6873</Color>
    <Color x:Key="StandardSurfaceColorValue">#FFFFFF</Color>
    <Color x:Key="StandardSurfaceAltColorValue">#F0F1F3</Color>

    <Color x:Key="PantryPrimaryColorValue">#755B8E</Color>
    <Color x:Key="PantryLightColorValue">#EEE8F3</Color>
    <Color x:Key="RecipeGreenColorValue">#789777</Color>

    <SolidColorBrush x:Key="MainWindowBackgroundBrush" Color="#F7F9FC"/>
    <SolidColorBrush x:Key="StandardWindowBackgroundBrush" Color="#F5F6F8"/>
    <SolidColorBrush x:Key="PantryWindowBackgroundBrush" Color="#F5F3F7"/>
    <SolidColorBrush x:Key="WindowTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F0F1F3"/>
    <SolidColorBrush x:Key="MainButtonHoverBrush" Color="#34495E"/>
    <SolidColorBrush x:Key="MainButtonPressedBrush" Color="#1A252F"/>
    <SolidColorBrush x:Key="MainMediumGrayBrush" Color="#BDC3C7"/>
    <SolidColorBrush x:Key="StandardHeaderSubtitleBrush" Color="#D9D4DF"/>
    <SolidColorBrush x:Key="StandardBorderBrush" Color="#D8D4DC"/>
    <SolidColorBrush x:Key="StandardKcalSubtitleBrush" Color="#EEE9F3"/>
    <SolidColorBrush x:Key="PantryBorderBrush" Color="#DDD7E2"/>
    <SolidColorBrush x:Key="PantryInputBorderBrush" Color="#CFC8D4"/>
    <SolidColorBrush x:Key="PantryMutedTextBrush" Color="#6F6973"/>
    <SolidColorBrush x:Key="RecipeInstructionBackgroundBrush" Color="#F7F5F8"/>
    <SolidColorBrush x:Key="RecipeInstructionBorderBrush" Color="#E3DEE6"/>
    <SolidColorBrush x:Key="PantryDeleteBrush" Color="#A86565"/>
    <SolidColorBrush x:Key="DestructiveRedBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="GeneratedListItemBackgroundBrush" Color="#F8F9FA"/>
    <SolidColorBrush x:Key="GeneratedListTextBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="RecipePercentBrush" Color="#9ABF75"/>
    <SolidColorBrush x:Key="GeneratedMutedTextBrush" Color="#808080"/>
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TransparentThemeBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="WhiteTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="StandardPrimaryBrush" Color="{DynamicResource StandardPrimaryColorValue}"/>
    <SolidColorBrush x:Key="PantryPrimaryBrush" Color="{DynamicResource PantryPrimaryColorValue}"/>
    <SolidColorBrush x:Key="ProgressTrackBrush" Color="#D8D4DC"/>
    <Color x:Key="CardShadowColorValue">#E2DCDC</Color>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource StandardPrimaryBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource StandardBorderBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource StandardPrimaryBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource StandardBorderBrush}"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource StandardBorderBrush}"/>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource SurfaceAltBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource PantryBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource PantryBorderBrush}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource DataGridHeaderBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource WindowTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PantryBorderBrush}"/>
    </Style>

</ResourceDictionary>
