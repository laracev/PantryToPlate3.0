<Window x:Class="PantryToPlate.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Laden..." Height="350" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize">
    <Grid Background="#665282">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <Border Grid.Row="1" Height="30" Width="400" Background="#AFA0C4" CornerRadius="8" Margin="20" HorizontalAlignment="Center">
            <Border x:Name="progressBar" Width="0" Background="#7FA36A" CornerRadius="8" HorizontalAlignment="Left"/>
        </Border>

        <TextBlock x:Name="txtStatus" Grid.Row="2" Text="Initialisiere..." Foreground="#D9D4DF" HorizontalAlignment="Center" Margin="10"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Ellipse x:Name="dot1" Width="10" Height="10" Fill="#FFC187F7" Margin="5">
                <Ellipse.RenderTransform>
                    <ScaleTransform CenterX="5" CenterY="5"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="dot2" Width="10" Height="10" Fill="#7FA36A" Margin="5">
                <Ellipse.RenderTransform>
                    <ScaleTransform CenterX="5" CenterY="5"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="dot3" Width="10" Height="10" Fill="#D7E3CF" Margin="5">
                <Ellipse.RenderTransform>
                    <ScaleTransform CenterX="5" CenterY="5"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="dot4" Width="10" Height="10" Fill="#F2F2F2" Margin="5">
                <Ellipse.RenderTransform>
                    <ScaleTransform CenterX="5" CenterY="5"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </StackPanel>
        <Image Height="100" Margin="185,107,194,57" Source="/Pics/Logo_animation.png" Stretch="Fill" Grid.RowSpan="2"/>
        <TextBlock Text="Pantry To Plate" FontSize="32" FontWeight="Bold" Foreground="White" Margin="138,45,134,107"/>
        <TextBlock FontSize="16" Foreground="#D9D4DF" HorizontalAlignment="Left" Margin="151,93,0,80"><Run Language="de-at" Text="Healthy Eating made easy •ᴗ•"/></TextBlock>
    </Grid>
</Window> 