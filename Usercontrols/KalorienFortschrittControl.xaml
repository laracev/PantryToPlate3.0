<UserControl x:Class="PantryToPlate.Usercontrols.KalorienFortschrittControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PantryToPlate.Usercontrols"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas x:Name="zeichnenCanvas" Grid.Row="0" Width="180" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Ellipse x:Name="hintergrundKreis" Width="160" Height="160" Stroke="#DDDDDD" StrokeThickness="12" Canvas.Left="10" Canvas.Top="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Path x:Name="fortschrittsBogen" Stroke="#A050A6" StrokeThickness="12"/>

            <TextBlock x:Name="txtProzent" Canvas.Left="46" Canvas.Top="76" FontSize="24" FontWeight="Bold" TextAlignment="Center" Width="100" Text="0%"/>
        </Canvas>
    </Grid>
</UserControl>
